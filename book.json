{
    "title": "个人笔记",
    "author": "Jack",
    "description": "Jack Hu, 风车大战骑士",
    "keywords": "markdown,gitbook,",
    "language": "zh-hans",
    "styles": {
        "website": "./styles/website.css"
    },
    "links": {
        "home": false,
        "about": false,
        "issues": false,
        "contribute": false,
        "sidebar": {
            "个人博客": "https://www.sohod.cn/"
        }
    },

    "plugins": [
        "-lunr", 
        "-search",
        "search-plus",
        "search-pro",
        "advanced-emoji",
        "include-codeblock",
        "accordion",
        "-sharing",
        "local-video",
        "simple-page-toc",
        "expandable-chapters",
        "chapter-fold",
        "favicon",
        "hide-element",
        "anchor-navigation-ex",
        "code",
        "atoc",
        "theme-comscore",
        "popup"
    ],

    "variables": {
        "themeFexa":{
            "nav":[
                {
                    "url":"http://sohod.cn",
                    "target":"_blank",
                    "name": "风车大战骑士"
                }
            ]
        }
    },

    "pluginsConfig": {

        "autocover": {
            "font": {
                "size": null,
                "family": "Impact",
                "color": "#FFF"
            },
            "size": {
                "w": 1800,
                "h": 2360
            },
            "background": {
                "color": "#09F"
            }
        },

        "simple-page-toc": {
            "maxDepth": 3,
            "skipFirstH1": true
        },

        "favicon": {
            "shortcut": "assets/images/favicon.ico",
            "bookmark": "assets/images/favicon.ico",
            "appleTouch": "assets/images/logo.png",
            "appleTouchMore": {
                "120x120": "assets/images/logo.png",
                "180x180": "assets/images/logo.png"
            }
        },

        "hide-element": {
            "elements": [".gitbook-link"]
        },

        "anchor-navigation-ex": {
            "showLevel": false,
            "showGoTop": true,
            "isRewritePageTitle": true,
            "isShowTocTitleIcon": true,
            "tocLevel1Icon": "fa fa-hand-o-right",
            "tocLevel2Icon": "fa fa-hand-o-right",
            "tocLevel3Icon": "fa fa-hand-o-right"
        },

        "code": {
            "copyButtons": true
        },

        "atoc": {
            "addClass": true,
            "className": "atoc"
        },

        "theme-default": {
            "showLevel": false
        },

        "theme-fexa":{
            "search-placeholder":"输入关键字搜索", 
            "logo":"./logo.png",
            "favicon": "./favicon.ico"
        }
    }
}


